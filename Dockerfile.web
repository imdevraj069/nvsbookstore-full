# ═══════════════════════════════════════════
# Dockerfile for Next.js frontend (monorepo)
# ═══════════════════════════════════════════

FROM node:20-alpine AS base
WORKDIR /app
RUN corepack enable && corepack prepare pnpm@10.30.0 --activate

# ── Dependencies ──
FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json apps/web/
COPY packages/ packages/
# Create a minimal pnpm-lock or install without frozen
RUN pnpm install --no-frozen-lockfile

# ── Build ──
FROM base AS builder
COPY --from=deps /app/ ./
COPY apps/web/ apps/web/

ENV NEXT_TELEMETRY_DISABLED=1
# API calls are relative (same origin via nginx), so leave empty
ENV NEXT_PUBLIC_API_URL=

WORKDIR /app/apps/web
RUN npx next build

# ── Runner ──
FROM node:20-alpine AS runner
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

WORKDIR /app

# Standalone output lives in .next/standalone (monorepo root structure)
# Copy the entire standalone output which includes node_modules
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./
# Copy static assets
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static
# Copy public directory if it exists
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

USER nextjs
EXPOSE 3000

ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

# In monorepo standalone, the server.js is at apps/web/server.js
CMD ["node", "apps/web/server.js"]
